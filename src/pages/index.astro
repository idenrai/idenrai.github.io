---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.date <= new Date()))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const techStack = [
  { name: 'Python',      color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'TypeScript',  color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Java',        color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'React',       color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'AWS',         color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Databricks',  color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Azure AI',    color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Docker',      color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Gen AI',      color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
  { name: 'Agile',       color: 'bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-300' },
];
---

<PageLayout title="Home">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

      <!-- Hero Section -->
      <section class="py-20 sm:py-28">
        <div class="flex flex-col sm:flex-row items-start gap-8">
          <div class="flex-1">
            <p class="text-accent-600 dark:text-accent-400 font-display font-medium text-sm tracking-widest uppercase mb-4">
              Data / AI Engineer · Tokyo, Japan
            </p>
            <h1 class="text-4xl sm:text-5xl font-display font-bold text-zinc-900 dark:text-zinc-50 leading-tight mb-6">
              안녕하세요,<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-600 to-accent-400">Youngjae Kwon</span>입니다.
            </h1>
            <p class="text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed mb-8 max-w-xl">
              일본에서 11년째 일하고 있는 엔지니어입니다.<br/>
              일하면서 배운 것들을 기록하고 있습니다.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/blog" class="btn-primary font-display font-medium">
                블로그 읽기
                <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a href="/about" class="btn-secondary">소개</a>
              <a
                href="https://github.com/idenrai"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.841-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.742 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                </svg>
                GitHub
              </a>
              <a
                href="https://www.linkedin.com/in/idenrai/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            </div>
          </div>

          <!-- 터미널 느낌의 데코 박스 -->
          <div class="hidden sm:block w-72 shrink-0">
            <div class="rounded-sm border border-zinc-200 dark:border-zinc-800 bg-zinc-950 overflow-hidden shadow-[8px_8px_0px_0px_rgba(37,99,235,0.15)] dark:shadow-[8px_8px_0px_0px_rgba(37,99,235,0.25)]">
              <div class="flex items-center justify-between px-4 py-2 border-b border-zinc-800 bg-zinc-900">
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-zinc-600"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-zinc-600"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-zinc-600"></span>
                </div>
                <span class="text-[10px] text-zinc-500 font-mono tracking-wider">zsh - ykwon</span>
              </div>
              <div class="p-5 font-mono text-xs text-zinc-300 leading-relaxed">
                <p class="text-accent-400"><span class="text-zinc-500">➜</span> ~ whoami</p>
                <p class="mt-1 text-zinc-400">youngjae kwon</p>
                <p class="mt-4 text-accent-400"><span class="text-zinc-500">➜</span> ~ cat career.txt</p>
                <p class="mt-1 text-zinc-400">· Deloitte (Data / AI)</p>
                <p class="text-zinc-400">· Accenture (FE / BE / AI)</p>
                <p class="text-zinc-400">· S.B.S. K.K. (SE)</p>
                <p class="mt-4 text-accent-400"><span class="text-zinc-500">➜</span> ~ cat interests.txt</p>
                <p class="mt-1 text-zinc-400">· Generative AI / LLM</p>
                <p class="text-zinc-400">· Data Engineering</p>
                <p class="text-zinc-400">· Cloud / AWS</p>
                <p class="mt-4 text-accent-400"><span class="text-zinc-500">➜</span> ~ <span class="animate-pulse w-2 h-4 bg-accent-400 inline-block align-middle"></span></p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 기술 스택 -->
      <section class="pb-16">
        <h2 class="text-xs font-display font-medium text-zinc-500 dark:text-zinc-500 uppercase tracking-widest mb-5">
          Tech Stack
        </h2>
        <div class="flex flex-wrap gap-2">
          {techStack.map(({ name, color }) => (
            <span class={`inline-block px-3 py-1.5 rounded-sm text-xs font-mono font-medium ${color}`}>
              {name}
            </span>
          ))}
        </div>
      </section>

      <div class="w-full h-px bg-zinc-200 dark:bg-zinc-800 mb-16" />

      <!-- 최근 포스트 -->
      <section class="pb-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xl font-display font-bold text-zinc-900 dark:text-zinc-50">최근 포스트</h2>
          <a href="/blog" class="text-sm font-medium text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 flex items-center gap-1 transition-colors">
            전체 보기 <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        {posts.length > 0 ? (
          <div class="grid gap-4">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                tags={post.data.tags}
                slug={post.slug}
              />
            ))}
          </div>
        ) : (
          <p class="text-gray-500 dark:text-gray-500 text-center py-12">
            아직 포스트가 없습니다.
          </p>
        )}
      </section>
    </div>
</PageLayout>
